---
import { directusAssetUrl, directusFetch, directusItemsUrl } from '../lib/directus';
import { getLocaleFromPath, withLocalePath } from '../lib/i18n';
import { buildProductSlugMap, getProductTitle } from '../lib/products';
import { slugifyLabel } from '../lib/slug';

interface Category {
	id?: number;
	status?: string;
	sort?: number;
	titolo_categoria?: string;
	descrizione_categoria?: string;
}

interface Project {
	id?: number;
	status?: string;
	titolo?: string;
	descrizione?: string;
	foto_principale?: string;
	anno?: number;
	categoria?: Category | number | null;
}

interface Props {
	titolo?: string;
	mode?: 'collections' | 'projects' | 'filterable-projects';
	selectedCollectionSlug?: string;
	useLightbox?: boolean;
}

const { titolo = '', mode = 'collections', selectedCollectionSlug = '', useLightbox = false } = Astro.props as Props;
const locale = getLocaleFromPath(Astro.url?.pathname ?? '/');
const isEnglish = locale === 'en';
const componentId = `portfolio-${Math.random().toString(36).slice(2)}`;

async function fetchCategories(): Promise<Category[]> {
	const url = directusItemsUrl('portfolio_categorie');
	url.searchParams.set('fields', 'id,status,sort,titolo_categoria,descrizione_categoria');
	url.searchParams.set('filter[status][_eq]', 'published');
	url.searchParams.set('sort', 'sort,titolo_categoria');
	url.searchParams.set('limit', '-1');
	const response = await directusFetch(url);
	if (!response.ok) return [];
	const payload = await response.json();
	return Array.isArray(payload?.data) ? (payload.data as Category[]) : [];
}

async function fetchProjects(): Promise<Project[]> {
	const url = directusItemsUrl('portfolio_opere');
	url.searchParams.set('fields', 'id,status,sort,titolo,descrizione,foto_principale,anno,categoria.id,categoria.titolo_categoria,categoria.status');
	url.searchParams.set('filter[status][_eq]', 'published');
	url.searchParams.set('sort', 'sort,titolo');
	url.searchParams.set('limit', '-1');
	const response = await directusFetch(url);
	if (!response.ok) return [];
	const payload = await response.json();
	return Array.isArray(payload?.data) ? (payload.data as Project[]) : [];
}

const [categories, projects] = await Promise.all([fetchCategories(), fetchProjects()]);
const productSlugMap = buildProductSlugMap(projects as any);
const enableMasonry = mode === 'filterable-projects';

const categoryById = new Map<number, { title: string; slug: string; description: string }>();
for (const category of categories) {
	if (typeof category.id !== 'number') continue;
	const title = category.titolo_categoria || String(category.id);
	categoryById.set(category.id, {
		title,
		slug: slugifyLabel(title) || String(category.id),
		description: category.descrizione_categoria || '',
	});
}

function categoryForProject(project: Project) {
	const raw = project.categoria;
	if (!raw) return null;
	if (typeof raw === 'number') return categoryById.get(raw) || null;
	if (typeof raw === 'object' && typeof raw.id === 'number') {
		const mapped = categoryById.get(raw.id);
		if (mapped) return mapped;
		const title = raw.titolo_categoria || String(raw.id);
		return { title, slug: slugifyLabel(title) || String(raw.id), description: '' };
	}
	return null;
}

const collections = Array.from(categoryById.values());
const collectionsWithProjects = collections.filter((collection) =>
	projects.some((project) => categoryForProject(project)?.slug === collection.slug)
);
const normalizedSelectedCollectionSlug = selectedCollectionSlug.trim();
const visibleProjects =
	mode === 'projects' && normalizedSelectedCollectionSlug
		? projects.filter((project) => categoryForProject(project)?.slug === normalizedSelectedCollectionSlug)
		: projects;

const collectionBasePath = isEnglish ? '/collection' : '/collezione';
const projectBasePath = isEnglish ? '/project' : '/progetto';
const allLabel = isEnglish ? 'All works' : 'Tutte le opere';
---

<section class={`portfolio_block portfolio_block_${mode}`} data-aos="fade-up" data-aos-duration="1200" id={componentId}>
	<div class="portfolio_block_inner">
		{titolo && <h2 class="portfolio_block_title">{titolo}</h2>}

		{mode === 'collections' ? (
			<div class="portfolio_collections_grid">
				{collections.map((collection) => (
					<a class="portfolio_collection_card" href={withLocalePath(`${collectionBasePath}/${collection.slug}`, locale)}>
						<h3>{collection.title}</h3>
						{collection.description && <p>{collection.description}</p>}
					</a>
				))}
			</div>
		) : (
			<>
				{mode === 'filterable-projects' && (
					<nav class="portfolio_filters" aria-label={isEnglish ? 'Portfolio categories' : 'Categorie portfolio'}>
						<button class="portfolio_filter is-active" type="button" data-category="all">{allLabel}</button>
						{collectionsWithProjects.map((collection) => (
							<button class="portfolio_filter" type="button" data-category={collection.slug}>{collection.title}</button>
						))}
					</nav>
				)}

				<div class="portfolio_projects_grid js-masonry-grid">
					<div class="grid-sizer"></div>
					<div class="gutter-sizer"></div>
					{visibleProjects.map((project) => {
						const title = getProductTitle(project as any) || (isEnglish ? 'Project' : 'Progetto');
						const slug = typeof project.id === 'number' ? productSlugMap.get(project.id) || String(project.id) : '';
						const category = categoryForProject(project);
						const image = project.foto_principale;
						return (
							<button
								type="button"
								class="portfolio_project_card grid-item"
								data-category={category?.slug || 'uncategorized'}
								data-title={title}
								data-year={project.anno ? String(project.anno) : ''}
								data-description={project.descrizione || ''}
								data-image={image ? directusAssetUrl(image) : ''}
								data-detail-url={withLocalePath(`${projectBasePath}/${slug}`, locale)}
							>
								{image && (
									<div class="portfolio_project_media">
										<img src={directusAssetUrl(image)} alt={title} loading="lazy" />
									</div>
								)}
							</button>
						);
					})}
				</div>

				{useLightbox && (
					<div class="portfolio_lightbox" data-open="false" aria-hidden="true">
						<div class="portfolio_lightbox_backdrop" data-close-lightbox></div>
						<div class="portfolio_lightbox_panel" role="dialog" aria-modal="true" aria-label={isEnglish ? 'Project preview' : 'Anteprima progetto'}>
							<button type="button" class="portfolio_lightbox_close" aria-label={isEnglish ? 'Close' : 'Chiudi'} data-close-lightbox>×</button>
							<div class="portfolio_lightbox_media"></div>
							<div class="portfolio_lightbox_content">
								<h3 class="portfolio_lightbox_title"></h3>
								<p class="portfolio_lightbox_year"></p>
								<div class="portfolio_lightbox_description"></div>
							</div>
						</div>
					</div>
				)}
			</>
		)}
	</div>
</section>

{mode !== 'collections' && (
	<script is:inline define:vars={{ componentId, useLightbox, enableMasonry }}>
		(() => {
			const root = document.getElementById(componentId);
			if (!root) return;
			const filters = Array.from(root.querySelectorAll('.portfolio_filter'));
			const cards = Array.from(root.querySelectorAll('.portfolio_project_card'));
			const grid = root.querySelector('.js-masonry-grid');
			let isotope = null;

			const loadScript = (src) =>
				new Promise((resolve, reject) => {
					const existing = document.querySelector(`script[src="${src}"]`);
					if (existing) {
						existing.addEventListener('load', () => resolve(true), { once: true });
						if (existing.dataset.loaded === 'true') resolve(true);
						return;
					}
					const script = document.createElement('script');
					script.src = src;
					script.async = true;
					script.addEventListener('load', () => {
						script.dataset.loaded = 'true';
						resolve(true);
					});
					script.addEventListener('error', reject);
					document.head.appendChild(script);
				});

			const initIsotope = async () => {
				if (!enableMasonry) return;
				if (!grid) return;
				try {
					await loadScript('https://unpkg.com/isotope-layout@3/dist/isotope.pkgd.min.js');
					await loadScript('https://unpkg.com/imagesloaded@5/imagesloaded.pkgd.min.js');
					if (!window.Isotope || !window.imagesLoaded) return;
					isotope = new window.Isotope(grid, {
						itemSelector: '.grid-item',
						layoutMode: 'masonry',
						columnWidth: '.grid-sizer',
						gutter: '.gutter-sizer',
						percentPosition: true,
						transitionDuration: '0.25s'
					});
					window.imagesLoaded(grid).on('progress', () => isotope && isotope.layout());
				} catch (_) {
					// Fallback: keep static grid if CDN is unavailable.
				}
			};

			const lightbox = useLightbox ? root.querySelector('.portfolio_lightbox') : null;
			const lightboxMedia = lightbox ? lightbox.querySelector('.portfolio_lightbox_media') : null;
			const lightboxTitle = lightbox ? lightbox.querySelector('.portfolio_lightbox_title') : null;
			const lightboxYear = lightbox ? lightbox.querySelector('.portfolio_lightbox_year') : null;
			const lightboxDescription = lightbox ? lightbox.querySelector('.portfolio_lightbox_description') : null;

			if (lightbox && lightbox.parentElement !== document.body) {
				document.body.appendChild(lightbox);
			}

			const openLightbox = (card) => {
				if (!lightbox || !lightboxMedia || !lightboxTitle || !lightboxYear || !lightboxDescription) return;
				const title = card.getAttribute('data-title') || '';
				const year = card.getAttribute('data-year') || '';
				const description = card.getAttribute('data-description') || '';
				const image = card.getAttribute('data-image') || '';

				lightboxTitle.textContent = title;
				lightboxYear.textContent = year;
				lightboxYear.style.display = year ? '' : 'none';
				lightboxDescription.textContent = description;
				lightboxMedia.innerHTML = image ? `<img src="${image}" alt="${title}">` : '';
				lightbox.setAttribute('data-open', 'true');
				lightbox.setAttribute('aria-hidden', 'false');
				document.body.style.overflow = 'hidden';
			};

			const closeLightbox = () => {
				if (!lightbox) return;
				lightbox.setAttribute('data-open', 'false');
				lightbox.setAttribute('aria-hidden', 'true');
				document.body.style.overflow = '';
			};

			if (lightbox) {
				root.querySelectorAll('[data-close-lightbox]').forEach((el) => {
					el.addEventListener('click', closeLightbox);
				});
				const panel = lightbox.querySelector('.portfolio_lightbox_panel');
				if (panel) {
					panel.addEventListener('click', (event) => {
						const target = event.target;
						if (!(target instanceof Element)) return;
						if (target.closest('.portfolio_lightbox_media img')) return;
						closeLightbox();
					});
				}
				document.addEventListener('keydown', (event) => {
					if (event.key === 'Escape') closeLightbox();
				});
			}

			cards.forEach((card) => {
				card.addEventListener('click', () => {
					if (!useLightbox) {
						const detailUrl = card.getAttribute('data-detail-url');
						if (detailUrl) window.location.href = detailUrl;
						return;
					}
					openLightbox(card);
				});
			});

			const setCategory = (value) => {
				filters.forEach((filter) => {
					const isActive = filter.getAttribute('data-category') === value;
					filter.classList.toggle('is-active', isActive);
				});

				if (isotope) {
					const filterValue = value === 'all' ? '*' : `[data-category="${value}"]`;
					isotope.arrange({ filter: filterValue });
				} else {
					cards.forEach((card) => {
						const category = card.getAttribute('data-category') || 'uncategorized';
						const visible = value === 'all' || category === value;
						card.style.display = visible ? '' : 'none';
					});
				}
			};

			filters.forEach((filter) => {
				filter.addEventListener('click', () => {
					const value = filter.getAttribute('data-category') || 'all';
					setCategory(value);
				});
			});

			initIsotope().then(() => {
				if (filters.length) setCategory('all');
			});
		})();
	</script>
)}

<style>
	.portfolio_block { padding: 28px 20px 90px; }
	.portfolio_block_inner { max-width: var(--max-width); margin: 0 auto; }
	.portfolio_block_title { margin: 0 0 22px; color: var(--bianco); font-size: clamp(38px, 7vw, 100px); font-weight: 500; letter-spacing: -0.01em; }
	.portfolio_collections_grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 24px; }
	.portfolio_projects_grid { width: 100%; }
	.portfolio_block_projects .portfolio_projects_grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 20px; }
	.grid-sizer,
	.gutter-sizer { width: 4.8%; }
	.grid-sizer { width: 30.1%; }
	.portfolio_collection_card,
	.portfolio_project_card { background: transparent; color: #f3f3f3; border-radius: 0; overflow: hidden; text-decoration: none; transition: transform .25s ease, opacity .25s ease; border: 0; box-shadow: none; }
	.portfolio_project_card { display: block; width: 30.1%; margin-bottom: 40px; }
	.portfolio_block_projects .grid-sizer,
	.portfolio_block_projects .gutter-sizer { display: none; }
	.portfolio_block_projects .portfolio_project_card { width: auto; margin: 0; aspect-ratio: 1 / 1; position: relative; z-index: 1; transform-origin: center; transition: transform .35s ease, opacity .25s ease, box-shadow .35s ease; }
	.portfolio_project_card { padding: 0; cursor: pointer; text-align: left; }
	a.portfolio_collection_card:hover,
	.portfolio_project_card:hover { transform: translateY(-2px); opacity: 0.92; }
	.portfolio_block_projects:has(.portfolio_project_card:hover)::before { content: ''; position: fixed; inset: 0; z-index: 40; pointer-events: none; background: rgba(0,0,0,.5); }
	.portfolio_project_media { background: transparent; }
	.portfolio_project_media img { width: 100%; height: auto; display: block; }
	.portfolio_block_projects .portfolio_project_media { width: 100%; height: 100%; }
	.portfolio_block_projects .portfolio_project_media img { width: 100%; height: 100%; object-fit: cover; filter: brightness(.6); transition: filter .3s ease, opacity .25s ease, transform .35s ease; }
	.portfolio_block_projects .portfolio_project_card:hover { z-index: 50; opacity: 1; transform: scale(1.2); box-shadow: 0 28px 90px rgba(0,0,0,.55); }
	.portfolio_block_projects .portfolio_project_card:hover .portfolio_project_media img { filter: brightness(1); opacity: 1; transform: scale(1.02); }
	.portfolio_collection_card h3,
	.portfolio_project_content h3 { margin: 16px 16px 8px; font-size: clamp(22px, 2.4vw, 36px); line-height: 1.08; font-weight: 500; }
	.portfolio_collection_card p,
	.portfolio_project_content p { margin: 0 16px 18px; line-height: 1.45; color: #c8c8c8; }
	.portfolio_project_meta { font-size: 12px; letter-spacing: .4px; text-transform: uppercase; font-weight: 700; margin-top: 18px; }
	.portfolio_project_year { font-weight: 700; }
	.portfolio_filters { display: flex; flex-wrap: wrap; gap: 12px; margin: 0 0 34px; justify-content: center; }
	.portfolio_filter { border: 1px solid rgba(255, 255, 255, .5); background: transparent; color: var(--bianco); padding: 15px 25px; border-radius: 999px; cursor: pointer; font-weight: 600; text-transform: uppercase; letter-spacing: .08em; font-size: 13px; margin-bottom: 40px; }
	.portfolio_filter.is-active { background: var(--primary); border-color: var(--primary); color: var(--nero); }
	.portfolio_lightbox { position: fixed; inset: 0; z-index: 1000; display: none; padding: 20px; width: 100vw; height: 100vh; align-items: center; justify-content: center; }
	.portfolio_lightbox[data-open="true"] { display: flex; }
	.portfolio_lightbox_backdrop { position: absolute; inset: 0; background: rgba(0, 0, 0, .72); }
	.portfolio_lightbox_panel { position: relative; z-index: 1; width: min(1040px, calc(100vw - 40px)); max-height: calc(100vh - 40px); margin: 0; overflow: auto; background: #111; border: 1px solid #2d2d2d; }
	.portfolio_lightbox_close { position: absolute; top: 10px; right: 10px; width: 36px; height: 36px; border: 0; background: rgba(0,0,0,.4); color: #fff; font-size: 24px; cursor: pointer; }
	.portfolio_lightbox_media img { width: 100%; height: auto; display: block; }
	.portfolio_lightbox_content { padding: 22px 24px 28px; }
	.portfolio_lightbox_title { margin: 0; font-size: clamp(16px, 1.4vw, 22px); line-height: 1.2; }
	.portfolio_lightbox_year { margin: 10px 0 0; color: var(--theme--primary); font-weight: 700; }
	.portfolio_lightbox_description { margin-top: 12px; color: #c8c8c8; line-height: 1.55; white-space: pre-wrap; }
	@media (max-width: 980px) {
		.grid-sizer,
		.portfolio_project_card { width: 47%; }
		.portfolio_block_projects .portfolio_projects_grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
		.gutter-sizer { width: 6%; }
		.portfolio_project_card { margin-bottom: 30px; }
		.portfolio_collections_grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
	}
	@media (max-width: 640px) {
		.portfolio_collections_grid { grid-template-columns: 1fr; }
		.portfolio_block_projects .portfolio_projects_grid { grid-template-columns: 1fr; }
		.grid-sizer,
		.portfolio_project_card { width: 100%; }
		.gutter-sizer { width: 0; }
		.portfolio_project_card { margin-bottom: 22px; }
		.portfolio_lightbox { padding: 12px; }
		.portfolio_lightbox_panel { width: calc(100vw - 24px); max-height: calc(100vh - 24px); }
		.portfolio_block_projects:has(.portfolio_project_card:hover)::before { display: none; }
		.portfolio_block_projects .portfolio_project_card:hover { transform: none; box-shadow: none; }
	}
</style>
