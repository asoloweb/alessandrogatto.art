---
import { directusAssetUrl } from '../lib/directus';

interface Props {
	item: string;
	titolo?: string;
	sottotitolo?: string;
	paragrafo?: string;
	href?: string;
	label?: string;
	immagine?: string;
	slides?: { immagine?: string | { id?: string | null } | null; titolo?: string }[];
	inverti?: boolean;
	background_color?: string;
}

const { 
	item, 
	titolo = '', 
	sottotitolo = '', 
	paragrafo = '', 
	href = '', 
	label = '', 
	immagine = '',
	slides = [],
	inverti = false,
	background_color = ''
} = Astro.props;

const hasSlider = Array.isArray(slides) && slides.length > 0;
const heroSliderId = `hero-slider-${item || Math.random().toString(36).slice(2)}`;

function resolveImageId(value: string | { id?: string | null } | null | undefined) {
	if (!value) return undefined;
	if (typeof value === 'string') return value;
	if (typeof value === 'object' && typeof value.id === 'string') return value.id;
	return undefined;
}

function resolveImageSrc(value: string | { id?: string | null } | null | undefined) {
	return directusAssetUrl(resolveImageId(value), {
		width: 1100,
		height: 900,
		quality: 74,
		format: 'webp',
		fit: 'cover',
	});
}
---

<div
	data-aos="fade-up"
     data-aos-duration="1500"
	class={`hero_block${inverti ? ' hero_block_inverted' : ''}`}
	style={background_color ? `background-color: ${background_color};` : undefined}
>
	{(immagine || hasSlider) && (
		<div class="colonna colonna_immagine">
			{hasSlider ? (
				<div class="hero_block_slider swiper" id={heroSliderId}>
					<div class="swiper-wrapper">
						{slides.map((slide, index) => {
							const imageSrc = resolveImageSrc(slide.immagine);
							if (!imageSrc) return null;
							return (
								<div class="swiper-slide hero_image_slide">
									<img
										class="hero_image"
										src={imageSrc}
										alt={slide.titolo || sottotitolo || titolo}
										loading={index === 0 ? 'eager' : 'lazy'}
										fetchpriority={index === 0 ? 'high' : 'auto'}
										decoding="async"
									/>
								</div>
							);
						})}
					</div>
					{slides.length > 1 && <div class="swiper-pagination"></div>}
				</div>
			) : (
				<img
					class="hero_image"
					data-aos="image-rotate"
					data-aos-duration="1000"
					data-aos-anchor-placement="top-bottom"
					src={resolveImageSrc(immagine)}
					alt={sottotitolo || titolo}
					loading="eager"
					fetchpriority="high"
					decoding="async"
				/>
			)}
			<div class="hero_decor" data-aos="rotate-cw" data-aos-duration="800" data-aos-delay="200"></div>
		</div>
	)}
	<div class="colonna colonna_testo">
		{titolo && <div class="title">{titolo}</div>}
		{sottotitolo && <h3>{sottotitolo}</h3>}
		{paragrafo && <div class="hero_text" set:html={paragrafo} />}
		{label && href && (
			<a class="MainButton" href={href}>
				{label}
			</a>
		)}
	</div>
</div>

<style>
	.hero_block {
		color:#fff;
		display: flex;
		border-radius: 0;
		max-width: var(--max-width);
		margin: auto;
		margin-bottom: 80px;
		border: 1px solid #2b2b2b;
		background: #0b0b0b;
		overflow: hidden;
	}
	.colonna {
		flex: 1;
	}

	.hero_block_inverted {
		flex-direction: row-reverse;
	}

	.colonna_testo {
		display: flex;
		flex-direction: column;
		justify-content: center;
		background: #111;
		color: #fff;
		padding: clamp(28px, 4vw, 56px);
		border-radius: 0;
	}

	.colonna_immagine {
		display: flex;
		align-items: center;
		justify-content: flex-start;
		position: relative;
		overflow: hidden;
	}

	.hero_block_slider {
		width: 100%;
		height: 100%;
	}

	.hero_image_slide {
		height: 100%;
	}

	.hero_block_inverted .colonna_immagine {
		justify-content: flex-end;
	}

	.colonna_testo .title {
		font-size: clamp(30px, 4.1vw, 58px);
		font-family: var(--font-heading);
		line-height: 1.05;
		font-weight: 500;
		letter-spacing: -0.01em;
	}

	.colonna_testo h3 {
		font-size: clamp(18px, 2.1vw, 28px);
		line-height: 1.25;
		font-weight: 400;
		margin: 14px 0 0;
		color: #f0f0f0;
	}

	.hero_text {
		margin: 16px 0 28px;
		line-height: 1.7;
		font-size: clamp(15px, 1.3vw, 18px);
		color: #cccccc;
	}

	.hero_text p {
		margin: 0;
	}
	.hero_image {
		max-width: 100%;
		margin-left: 0;
		height: auto;
		display: block;
		object-fit: cover;
		height: 100%;
		object-position: center;
		border-radius: 0;
	}

	:global(.hero_block_slider .swiper-pagination) {
		bottom: 14px !important;
	}

	:global(.hero_block_slider .swiper-pagination-bullet) {
		background: rgba(255, 255, 255, 0.5);
		opacity: 1;
	}

	:global(.hero_block_slider .swiper-pagination-bullet-active) {
		background: #fff;
	}
	
	.hero_image[data-aos="image-rotate"] {
		opacity: 0;
		transform: none;
		transition: opacity 0.8s ease-out, transform 0.35s ease;
	}
	
	.hero_image[data-aos="image-rotate"].aos-animate {
		opacity: 1;
		transform: none;
	}

	.colonna_immagine:hover .hero_image[data-aos="image-rotate"].aos-animate {
		transform: scale(1.03);
	}
	
	.hero_block:not(.hero_block_inverted) .hero_image {
		margin-right: 0;
	}

	.hero_decor {
		display: none;
	}

	.hero_block_inverted .hero_decor {
		animation: decorRotateInverted 0.8s ease-out 0.3s forwards;
	}

	@keyframes decorRotate {
		from { transform: translateX(-50%) rotate(0deg); }
		to { transform: translateX(-50%) rotate(3deg); }
	}

	@keyframes decorRotateInverted {
		from { transform: translateX(-50%) rotate(0deg); }
		to { transform: translateX(-50%) rotate(-3deg); }
	}

	@media (max-width: 768px) {
		.hero_block {
			flex-direction: column;
			margin-bottom: 40px;
		}

		.hero_block_inverted {
			flex-direction: column;
		}

		.colonna_immagine {
			height: 300px;
		}

		.hero_image {
			max-width: 100%;
			margin-left: 0;
			height: 100%;
			object-position: center;
			border-radius: 0;
		}

		.hero_block:not(.hero_block_inverted) .hero_image {
			margin-right: 0;
		}

		.colonna_testo {
			padding: 24px;
			border-radius: 0;
		}

		.hero_text {
			font-size: 16px;
			line-height: 22px;
		}

	}
</style>
