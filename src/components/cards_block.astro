---
import { directusAssetUrl } from '../lib/directus';
import { englishSlugFromItalian, getLocaleFromPath, withLocalePath } from '../lib/i18n';

interface PageRef {
	id?: number;
	slug?: string;
	slug_en?: string;
}

interface SingleCard {
	id?: number;
	titolo_card?: string;
	sottotitolo_card?: string;
	immagine?: string;
	href?: string;
	link?: PageRef | number | null;
	link_label?: string;
}

interface CardRelation {
	single_card_id?: SingleCard | number | null;
}

interface Props {
	titolo?: string;
	card?: CardRelation[] | SingleCard[];
}

const { titolo = '', card = [] } = Astro.props;
const locale = getLocaleFromPath(Astro.url?.pathname ?? '/');

function resolveImageSrc(value: string | undefined) {
	return directusAssetUrl(value);
}

function normalizeCards(input: CardRelation[] | SingleCard[]) {
	if (!Array.isArray(input)) return [];
	return input
		.map((entry) => {
			if (!entry || typeof entry !== 'object') return null;
			if ('single_card_id' in entry) {
				return entry.single_card_id && typeof entry.single_card_id === 'object'
					? (entry.single_card_id as SingleCard)
					: null;
			}
			if (
				'titolo_card' in entry ||
				'sottotitolo_card' in entry ||
				'immagine' in entry ||
				'href' in entry ||
				'link_label' in entry
			) {
				return entry as SingleCard;
			}
			return null;
		})
		.filter((entry): entry is SingleCard => Boolean(entry));
}

function getCardHref(card: SingleCard) {
	if (card.href) {
		if (card.href.startsWith('http://') || card.href.startsWith('https://') || card.href.startsWith('#')) return card.href;
		return withLocalePath(locale === 'en' ? card.href.replace(/^\/(.+)/, (_m, first) => `/${englishSlugFromItalian(first)}`) : card.href, locale);
	}
	if (card.link && typeof card.link === 'object' && card.link.slug) {
		const baseSlug = locale === 'en' ? card.link.slug_en || englishSlugFromItalian(card.link.slug) : card.link.slug;
		if (!baseSlug || baseSlug === 'home') return withLocalePath('/', locale);
		return withLocalePath(`/${baseSlug}`, locale);
	}
	return '';
}

const cards = normalizeCards(card);
---

{cards.length > 0 && (
	<section class="cards_block" data-aos="fade-up" data-aos-duration="1500">
		<div class="cards_block_inner">
			{titolo && <h2 class="cards_block_title">{titolo}</h2>}

			<div class="cards_grid">
				{cards.map((single) => {
					const href = getCardHref(single);
					const hasLabelLink = Boolean(single.link_label?.trim());
					const Tag = href ? 'a' : 'div';
					const imageSrc = resolveImageSrc(single.immagine);

					return (
						<Tag class="cards_card" href={href || undefined}>
							{imageSrc && (
								<div class="cards_card_media">
									<img src={imageSrc} alt={single.titolo_card || ''} loading="lazy" />
								</div>
							)}
							{single.titolo_card && <h3 class="cards_card_title">{single.titolo_card}</h3>}
							{single.sottotitolo_card && (
								<p class="cards_card_subtitle">{single.sottotitolo_card}</p>
							)}
							{hasLabelLink && <span class="cards_card_link">{single.link_label}</span>}
						</Tag>
					);
				})}
			</div>
		</div>
	</section>
)}

<style>
	.cards_block {
		padding: 56px 20px 24px;
	}

	.cards_block_inner {
		max-width: var(--max-width);
		margin: 0 auto;
	}

	.cards_block_title {
		margin: 0 0 30px;
		color: var(--bianco);
		font-size: clamp(34px, 6vw, 84px);
		font-weight: 500;
		letter-spacing: -0.01em;
	}

	.cards_grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 24px;
	}

	.cards_card {
		display: flex;
		flex-direction: column;
		gap: 12px;
		padding: 34px 28px;
		background: var(--surface);
		border-radius: 0;
		border: 1px solid var(--border);
		color: var(--bianco);
		transition: transform 200ms ease, box-shadow 200ms ease;
		min-height: 100%;
		transition: all .32s ease-out;
	}

	.cards_card:hover {
		transform: translateY(-3px);
	} 

	a.cards_card:hover {
		box-shadow: 0 22px 34px rgba(0, 0, 0, 0.35);
		border-color: #4e4e4e;
	}

	.cards_card_media {
		overflow: hidden;
		border-radius: 0;
		aspect-ratio: 4 / 3;
		background: #0a0a0a;
		border: 1px solid #2a2a2a;
	}

	.cards_card_media img {
		width: 100%;
		height: 100%;
		object-fit: contain;
	}

	.cards_card_title {
		margin: 4px 0 0;
		font-size: clamp(24px, 2.5vw, 38px);
		line-height: 1.05;
		text-align: left;
		font-weight: 500;
	}

	.cards_card_subtitle {
		margin: 0;
		font-size: 15px;
		line-height: 1.45;
		color: var(--text-muted);
	}

	.cards_card_link {
		margin-top: auto;
		align-self: flex-start;
		font-weight: 600;
		font-size: 12px;
		letter-spacing: 0.09em;
		text-transform: uppercase;
		text-underline-offset: 2px;
		width: auto;
		text-align: left;
		color: var(--bianco);
		text-decoration: none;
	}

	@media (max-width: 1024px) {
		.cards_grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 640px) {
		.cards_grid {
			grid-template-columns: 1fr;
		}
	}
</style>
