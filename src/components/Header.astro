---

import { DIRECTUS_URL, directusFetch, directusItemsUrl } from '../lib/directus';
import { englishPathFromItalian, englishSlugFromItalian, getLocaleFromPath, italianPathFromEnglish, localizedField, withLocalePath } from '../lib/i18n';

interface MenuItem {
	id?: number | string;
	label?: string;
	label_en?: string;
	custom_href?: string;
	custom_href_en?: string;
	pages?: { pages_id?: PageItem | number | string }[] | PageItem[];
}

interface Menu {
	id: number;
	slug?: string;
	titolo?: string;
	menu_items?: MenuItem[] | (number | string)[];
}

interface PageItem {
	id?: number;
	slug?: string;
	slug_en?: string;
	title?: string;
	title_en?: string;
}

interface Options {
	logo_light?: string;
}

let logoLightSrc = import.meta.env.PUBLIC_LOGO_LIGHT || '/favicon.svg';
const currentPath = Astro.url?.pathname ?? '/';
const currentLocale = getLocaleFromPath(currentPath);
const currentItalianPath = withLocalePath(currentPath, 'it');
const currentEnglishPath = currentLocale === 'it' ? englishPathFromItalian(currentItalianPath) : currentItalianPath;
const italianPath = currentLocale === 'en' ? italianPathFromEnglish(currentItalianPath) : currentItalianPath;
const englishPath = withLocalePath(currentEnglishPath, 'en');

let menuItems: MenuItem[] = [];
const fallbackMenuItems: MenuItem[] = [
	{ label: 'HOME', label_en: 'HOME', custom_href: '/', custom_href_en: '/' },
	{ label: 'CHI SONO', label_en: 'ABOUT', custom_href: '/chi-sono-filosofia', custom_href_en: '/about-philosophy' },
	{ label: 'PORTFOLIO', label_en: 'PORTFOLIO', custom_href: '/portfolio', custom_href_en: '/portfolio' },
	{ label: 'PALMARES', label_en: 'PALMARES', custom_href: '/palmares', custom_href_en: '/palmares' },
	{ label: 'ALTRO', label_en: 'OTHER', custom_href: '/altro', custom_href_en: '/other' },
	{ label: 'RICONOSCIMENTI', label_en: 'AWARDS', custom_href: '/riconoscimenti', custom_href_en: '/awards' },
	{ label: 'COLLEZIONE', label_en: 'COLLECTION', custom_href: '/collezione', custom_href_en: '/collection' },
	{ label: 'CONTATTI', label_en: 'CONTACTS', custom_href: '/contatti', custom_href_en: '/contacts' },
];

function isPalmaresItem(item: MenuItem) {
	return item.custom_href === '/palmares' || item.custom_href_en === '/palmares' || item.label?.toLowerCase() === 'palmares';
}

function isPortfolioItem(item: MenuItem) {
	return item.custom_href === '/portfolio' || item.custom_href_en === '/portfolio' || item.label?.toLowerCase() === 'portfolio';
}

function isAltroItem(item: MenuItem) {
	const label = item.label?.toLowerCase();
	const labelEn = item.label_en?.toLowerCase();
	return item.custom_href === '/altro' || item.custom_href_en === '/other' || label === 'altro' || labelEn === 'other';
}

function isEventsItem(item: MenuItem) {
	const label = item.label?.toLowerCase();
	const labelEn = item.label_en?.toLowerCase();
	return item.custom_href === '/eventi' || item.custom_href_en === '/events' || label === 'eventi' || labelEn === 'events';
}

function normalizeMenuOrder(items: MenuItem[]) {
	const nextItems = items.filter((item) => !isPalmaresItem(item) && !isAltroItem(item) && !isEventsItem(item));
	const palmaresItem = items.find(isPalmaresItem) || fallbackMenuItems.find(isPalmaresItem);
	const altroItem = items.find(isAltroItem) || fallbackMenuItems.find(isAltroItem);
	const portfolioIndex = nextItems.findIndex(isPortfolioItem);
	if (palmaresItem && portfolioIndex >= 0) {
		nextItems.splice(portfolioIndex + 1, 0, palmaresItem);
	}
	const palmaresIndex = nextItems.findIndex(isPalmaresItem);
	if (altroItem && palmaresIndex >= 0) {
		nextItems.splice(palmaresIndex + 1, 0, altroItem);
	}
	return nextItems;
}

try {
	const optionsUrl = directusItemsUrl('options');
	optionsUrl.searchParams.set('fields', 'logo_light');
	const optionsResponse = await directusFetch(optionsUrl);
	if (optionsResponse.ok) {
		const optionsPayload = await optionsResponse.json();
		const options =
			optionsPayload?.data && Array.isArray(optionsPayload.data)
				? optionsPayload.data[0]
				: optionsPayload?.data;
		if (options?.logo_light) {
			logoLightSrc = resolveImageSrc(options.logo_light);
		}
	}

	const url = directusItemsUrl('Menus');
	url.searchParams.set('filter[slug][_eq]', 'menu-principale');
	url.searchParams.set(
		'fields',
		'menu_items.menu_items_id.id,menu_items.menu_items_id.label,menu_items.menu_items_id.label_en,menu_items.menu_items_id.custom_href,menu_items.menu_items_id.custom_href_en,menu_items.menu_items_id.pages.pages_id.id,menu_items.menu_items_id.pages.pages_id.slug,menu_items.menu_items_id.pages.pages_id.slug_en,menu_items.menu_items_id.pages.pages_id.title,menu_items.menu_items_id.pages.pages_id.title_en'
	);
	const response = await directusFetch(url);
	if (!response.ok) {
		menuItems = fallbackMenuItems;
		if (response.status !== 401 && response.status !== 403) {
			console.warn(`[Directus] Header menu unavailable (${response.status}), using fallback menu.`);
		}
	} else {
		const data = await response.json();
		const menu: Menu | undefined = (data.data || [])[0];
		const rawItems = Array.isArray(menu?.menu_items) ? menu.menu_items : [];
		const itemObjects = rawItems
			.map((item) => {
				if (!item || typeof item !== 'object') return null;
				if ('menu_items_id' in item && item.menu_items_id && typeof item.menu_items_id === 'object') {
					return item.menu_items_id as MenuItem;
				}
				return item as MenuItem;
			})
			.filter((item): item is MenuItem => Boolean(item));

		menuItems = itemObjects.length ? itemObjects : fallbackMenuItems;
	}
} catch (error) {
	menuItems = fallbackMenuItems;
	console.warn('Error fetching menu from Directus, using fallback menu.', error);
}

menuItems = normalizeMenuOrder(menuItems);

function resolveImageSrc(value: string) {
	if (!value) return '';
	if (value.startsWith('http://') || value.startsWith('https://') || value.startsWith('/')) {
		return value;
	}
	return `${DIRECTUS_URL}/assets/${value}`;
}

function getItemPage(item: MenuItem): PageItem | null {
	const rawPages = item.pages;
	if (!rawPages || !Array.isArray(rawPages)) return null;
	const normalizedPages = rawPages
		.map((page) => {
			if (!page) return null;
			if (typeof page === 'object' && 'pages_id' in page) {
				return page.pages_id && typeof page.pages_id === 'object'
					? (page.pages_id as PageItem)
					: null;
			}
			if (typeof page === 'object' && 'slug' in page) {
				return page as PageItem;
			}
			return null;
		})
		.filter((page): page is PageItem => Boolean(page));

	return normalizedPages[0] ?? null;
}

function getItemHref(item: MenuItem) {
	const customHref = currentLocale === 'en' ? item.custom_href_en || item.custom_href : item.custom_href;
	if (customHref) {
		if (customHref.startsWith('http://') || customHref.startsWith('https://') || customHref.startsWith('#')) {
			return customHref;
		}
		const localizedHref = currentLocale === 'en' ? englishPathFromItalian(customHref) : customHref;
		return withLocalePath(localizedHref, currentLocale);
	}
	const page = getItemPage(item);
	const pageSlug =
		currentLocale === 'en'
			? page?.slug_en || englishSlugFromItalian(page?.slug || '')
			: page?.slug;
	if (!pageSlug || pageSlug === 'home') return withLocalePath('/', currentLocale);
	return withLocalePath(`/${pageSlug}`, currentLocale);
}

function normalizePath(path: string) {
	if (!path) return '/';
	let cleanPath = path.split('?')[0].split('#')[0];
	if (cleanPath.length > 1 && cleanPath.endsWith('/')) {
		cleanPath = cleanPath.slice(0, -1);
	}
	return cleanPath;
}

function isCurrentMenuItem(href: string) {
	if (!href) return false;
	const base = Astro.url?.origin || 'http://localhost';
	try {
		const url = new URL(href, base);
		return normalizePath(url.pathname) === normalizePath(currentPath);
	} catch {
		return false;
	}
}

function getItemTitle(item: MenuItem, index: number) {
	return (
		localizedField(item, 'label', currentLocale) ||
		localizedField(getItemPage(item), 'title', currentLocale) ||
		`Link ${index + 1}`
	);
}
---

<header class="site-header" data-aos="fade-down" data-aos-duration="1000">
	<div class="site-topbar">
		<div class="site-topbar-inner">
			<div class="site-language-switch" aria-label="Selettore lingua">
				<a href={italianPath} class={currentLocale === 'it' ? 'active' : ''}>🇮🇹 IT</a>
				<a href={englishPath} class={currentLocale === 'en' ? 'active' : ''}>🇬🇧 EN</a>
			</div>
		</div>
	</div>
	<nav aria-label="Menu principale">
		<div>
			<a href="/">
				<span class="logo-signature" aria-hidden="true">
					<img class="MenuLogo" src={logoLightSrc} alt="Logo" />
				</span>
			</a>
		</div>
		<div class="MenuItemsContainer">
		{menuItems.map((item, index) => {
			const href = getItemHref(item);
			const title = getItemTitle(item, index);
			const isCurrent = isCurrentMenuItem(href);
			const className = isCurrent ? 'menu_item current_menu_item' : 'menu_item';
			return (
				<a href={href} class={className}>
					{title}
				</a>
			);
		})}
		</div>
		<button class="hamburger_button mburger MainButton" type="button" aria-label="Menu" aria-expanded="false">
			<b></b>
			<b></b>
			<b></b>
		</button>
	</nav>
</header>

<script is:inline>
(() => {
	const button = document.querySelector('.hamburger_button');
	const menu = document.querySelector('.MenuItemsContainer');
	const header = document.querySelector('.site-header');
	if (!button || !menu || !header) return;

	button.addEventListener('click', () => {
		const isOpen = menu.classList.toggle('is-open');
		button.classList.toggle('is-active', isOpen);
		button.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
	});

	const setFixed = (isFixed) => {
		if (isFixed) {
			header.classList.add('site-header-fixed');
			if (!header.dataset.fixedAnimated) {
				header.classList.remove('site-header-fixed-animate');
				void header.offsetWidth;
				header.classList.add('site-header-fixed-animate');
				header.dataset.fixedAnimated = 'true';
			}
		} else {
			header.classList.remove('site-header-fixed');
		}
	};

	const updateFixedState = () => {
		const isFixed = window.scrollY > 300;
		setFixed(isFixed);
	};

	window.addEventListener(
		'scroll',
		updateFixedState,
		{ passive: true }
	);

	window.addEventListener('resize', updateFixedState);
	updateFixedState();
})();
</script>
