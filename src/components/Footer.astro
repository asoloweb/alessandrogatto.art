---
import { DIRECTUS_URL, directusFetch, directusItemsUrl } from '../lib/directus';
import { englishPathFromItalian, englishSlugFromItalian, getLocaleFromPath, localizedField, withLocalePath } from '../lib/i18n';

interface MenuItem {
	id?: number | string;
	label?: string;
	label_en?: string;
	custom_href?: string;
	custom_href_en?: string;
	pages?: { pages_id?: PageItem | number | string }[] | PageItem[];
}

interface Menu {
	id: number;
	slug?: string;
	titolo?: string;
	menu_items?: MenuItem[] | (number | string)[];
}

interface PageItem {
	id?: number;
	slug?: string;
	slug_en?: string;
	title?: string;
	title_en?: string;
}

interface Options {
	logo_light?: string;
	footer_text?: string;
	footer_text_en?: string;
}

let logoLightSrc = import.meta.env.PUBLIC_LOGO_LIGHT || '/favicon.svg';
let footerText = '';
const currentLocale = getLocaleFromPath(Astro.url?.pathname ?? '/');
const footerMenus = [
	{ slug: 'footer-azienda', items: [] as MenuItem[] },
	{ slug: 'footer-servizi', items: [] as MenuItem[] },
	{ slug: 'footer-info', items: [] as MenuItem[] },
	{ slug: 'footer-contatti', items: [] as MenuItem[] },
];
const fallbackFooterMenus: Record<string, MenuItem[]> = {
	'footer-azienda': [
		{ label: 'Chi sono / Filosofia', label_en: 'About / Philosophy', custom_href: '/chi-sono-filosofia', custom_href_en: '/about-philosophy' },
		{
			label: 'Riconoscimenti',
			label_en: 'Awards',
			custom_href: '/riconoscimenti',
			custom_href_en: '/awards',
		},
	],
	'footer-servizi': [
		{ label: 'Portfolio', label_en: 'Portfolio', custom_href: '/portfolio', custom_href_en: '/portfolio' },
		{ label: 'Altro', label_en: 'Other', custom_href: '/altro', custom_href_en: '/other' },
		{ label: 'Collezione', label_en: 'Collection', custom_href: '/collezione', custom_href_en: '/collection' },
	],
	'footer-info': [],
	'footer-contatti': [
		{ label: 'Contatti', label_en: 'Contacts', custom_href: '/contatti', custom_href_en: '/contacts' },
	],
};
const fallbackFooterText =
	currentLocale === 'en'
		? '<p>Alessandro Gatto Art | <a href="mailto:info@alessandrogatto.art">info@alessandrogatto.art</a></p>'
		: '<p>Alessandro Gatto Art | <a href="mailto:info@alessandrogatto.art">info@alessandrogatto.art</a></p>';

try {
	const optionsUrl = directusItemsUrl('options');
	optionsUrl.searchParams.set('fields', 'logo_light,footer_text');
	const optionsResponse = await directusFetch(optionsUrl);
	if (optionsResponse.ok) {
		const optionsPayload = await optionsResponse.json();
		const options =
			optionsPayload?.data && Array.isArray(optionsPayload.data)
				? optionsPayload.data[0]
				: optionsPayload?.data;
		if (options?.logo_light) {
			logoLightSrc = resolveImageSrc(options.logo_light);
		}
		if (options?.footer_text) {
			footerText =
				currentLocale === 'en' ? options.footer_text_en || options.footer_text : options.footer_text;
		}
	} else {
		footerText = fallbackFooterText;
	}

	const menuFields =
		'menu_items.menu_items_id.id,menu_items.menu_items_id.label,menu_items.menu_items_id.label_en,menu_items.menu_items_id.custom_href,menu_items.menu_items_id.custom_href_en,menu_items.menu_items_id.pages.pages_id.id,menu_items.menu_items_id.pages.pages_id.slug,menu_items.menu_items_id.pages.pages_id.slug_en,menu_items.menu_items_id.pages.pages_id.title,menu_items.menu_items_id.pages.pages_id.title_en';

	for (const footerMenu of footerMenus) {
		const url = directusItemsUrl('Menus');
		url.searchParams.set('filter[slug][_eq]', footerMenu.slug);
		url.searchParams.set('fields', menuFields);
		const response = await directusFetch(url);
		if (!response.ok) {
			footerMenu.items = fallbackFooterMenus[footerMenu.slug] || [];
			if (response.status !== 401 && response.status !== 403) {
				console.warn(`[Directus] Footer menu '${footerMenu.slug}' unavailable (${response.status}), using fallback.`);
			}
			continue;
		}
		const data = await response.json();
		const menu: Menu | undefined = (data.data || [])[0];
		const rawItems = Array.isArray(menu?.menu_items) ? menu.menu_items : [];
		const itemObjects = rawItems
			.map((item) => {
				if (!item || typeof item !== 'object') return null;
				if ('menu_items_id' in item && item.menu_items_id && typeof item.menu_items_id === 'object') {
					return item.menu_items_id as MenuItem;
				}
				return item as MenuItem;
			})
			.filter((item): item is MenuItem => Boolean(item));

		footerMenu.items = (itemObjects.length ? itemObjects : fallbackFooterMenus[footerMenu.slug] || []).filter((item) => {
			const label = item.label?.toLowerCase();
			const labelEn = item.label_en?.toLowerCase();
			return item.custom_href !== '/eventi' && item.custom_href_en !== '/events' && label !== 'eventi' && labelEn !== 'events';
		});
	}
} catch (error) {
	for (const footerMenu of footerMenus) {
		if (!footerMenu.items.length) {
			footerMenu.items = fallbackFooterMenus[footerMenu.slug] || [];
		}
	}
	if (!footerText) {
		footerText = fallbackFooterText;
	}
	console.warn('Error fetching footer menu from Directus, using fallback menu.', error);
}

function resolveImageSrc(value: string) {
	if (!value) return '';
	if (value.startsWith('http://') || value.startsWith('https://') || value.startsWith('/')) {
		return value;
	}
	return `${DIRECTUS_URL}/assets/${value}`;
}

function getItemPage(item: MenuItem): PageItem | null {
	const rawPages = item.pages;
	if (!rawPages || !Array.isArray(rawPages)) return null;
	const normalizedPages = rawPages
		.map((page) => {
			if (!page) return null;
			if (typeof page === 'object' && 'pages_id' in page) {
				return page.pages_id && typeof page.pages_id === 'object'
					? (page.pages_id as PageItem)
					: null;
			}
			if (typeof page === 'object' && 'slug' in page) {
				return page as PageItem;
			}
			return null;
		})
		.filter((page): page is PageItem => Boolean(page));

	return normalizedPages[0] ?? null;
}

function getItemHref(item: MenuItem) {
	const customHref = currentLocale === 'en' ? item.custom_href_en || item.custom_href : item.custom_href;
	if (customHref) {
		if (customHref.startsWith('http://') || customHref.startsWith('https://') || customHref.startsWith('#')) {
			return customHref;
		}
		const localizedHref = currentLocale === 'en' ? englishPathFromItalian(customHref) : customHref;
		return withLocalePath(localizedHref, currentLocale);
	}
	const page = getItemPage(item);
	const pageSlug = currentLocale === 'en' ? page?.slug_en || englishSlugFromItalian(page?.slug || '') : page?.slug;
	if (!pageSlug || pageSlug === 'home') return withLocalePath('/', currentLocale);
	return withLocalePath(`/${pageSlug}`, currentLocale);
}

function getItemTitle(item: MenuItem, index: number) {
	return (
		localizedField(item, 'label', currentLocale) ||
		localizedField(getItemPage(item), 'title', currentLocale) ||
		`Link ${index + 1}`
	);
}
---

<footer class="site-footer">
	<nav aria-label="Menu footer">
		<div>
			<a href="/">
				<img class="MenuLogo" src={logoLightSrc} alt="Logo" />
			</a>
		</div>
		<div class="FooterItemsContainer">
			{footerMenus.map((footerMenu) => (
				<div class="FooterMenuColumn">
					{footerMenu.items.map((item, index) => {
						const href = getItemHref(item);
						const title = getItemTitle(item, index);
						return (
							<a href={href} class="menu_item">
								{title}
							</a>
						);
					})}
				</div>
			))}
		</div>
	</nav>
	<div class="footer_data" set:html={footerText} />
	<p class="footer_rights">Tutti i diritti delle immagini sono riservati. Ogni riproduzione, anche parziale, è vietata senza l'autorizzazione dell'artista.</p>
</footer>
