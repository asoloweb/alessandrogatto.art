---
import { directusAssetUrl } from '../lib/directus';

interface SlideItem {
	titolo?: string;
	sottotitolo?: string;
	label?: string;
	href?: string;
	immagine?: string | { id?: string | null } | null;
	video_sfondo?: string | { id?: string | null } | null;
}

interface Props {
	slides?: SlideItem[];
	titolo?: string;
	sottotitolo?: string;
	label?: string;
	href?: string;
}

const {
	slides = [],
	titolo = '',
	sottotitolo = '',
	label = '',
	href = '',
} = Astro.props;

const resolvedSlides =
	slides.length > 0
		? slides
		: [
				{
					titolo,
					sottotitolo,
					label,
					href,
				},
		  ];

const hasMultipleSlides = resolvedSlides.length > 1;

const sliderId = `slider-${Math.random().toString(36).slice(2)}`;

function resolveImageId(value: SlideItem['immagine']) {
	if (!value) return undefined;
	if (typeof value === 'string') return value;
	if (typeof value === 'object' && typeof value.id === 'string') return value.id;
	return undefined;
}

function resolveImageSrc(value: SlideItem['immagine']) {
	return directusAssetUrl(resolveImageId(value), {
		width: 1920,
		height: 1080,
		quality: 72,
		format: 'webp',
		fit: 'cover',
	});
}

function resolveVideoId(value: SlideItem['video_sfondo']) {
	if (!value) return undefined;
	if (typeof value === 'string') return value;
	if (typeof value === 'object' && typeof value.id === 'string') return value.id;
	return undefined;
}

function resolveVideoSrc(value: SlideItem['video_sfondo']) {
	return directusAssetUrl(resolveVideoId(value));
}
---

<div class="slider_block swiper" id={sliderId}>
	<div class="swiper-wrapper">
		{resolvedSlides.map((slide, index) => {
			const imageSrc = resolveImageSrc(slide.immagine);
			const videoSrc = resolveVideoSrc(slide.video_sfondo);
			const hasVideo = Boolean(videoSrc);
			return (
				<div class="swiper-slide single_slide" style={!hasVideo && imageSrc ? `background-image: url('${imageSrc}')` : undefined}>
					{videoSrc && (
						<video
							class="single_slide_video"
							src={videoSrc}
							autoplay
							muted
							loop
							playsinline
							preload="auto"
							aria-hidden="true"
						/>
					)}
					{!hasVideo && imageSrc && (
						<img
							class="single_slide_bg"
							src={imageSrc}
							alt={slide.titolo || ''}
							loading={index === 0 ? 'eager' : 'lazy'}
							fetchpriority={index === 0 ? 'high' : 'auto'}
							decoding="async"
						/>
					)}
					<div class="swiper-slide-container">
						{slide.titolo && <h1 data-aos="fade-up" data-aos-duration="1500">{slide.titolo}</h1>}
						{slide.sottotitolo && <h2 data-aos="fade-up" data-aos-duration="1800">{slide.sottotitolo}</h2>}
						{slide.label && slide.href && (
							<button data-aos="fade-up" data-aos-duration="2000" class="slider_button MainButton" type="button" data-href={slide.href}>
								{slide.label}
							</button>
						)}
						{(imageSrc || videoSrc) && <span class="slide_image_sr" aria-hidden="true"></span>}
					</div>
				</div>
			);
		})}
	</div>
	{hasMultipleSlides && <div class="swiper-pagination"></div>}
	{hasMultipleSlides && <div class="swiper-button-prev"></div>}
	{hasMultipleSlides && <div class="swiper-button-next"></div>}
</div>


<style>
		.title_block {
			margin: 32px 0 16px;
			border-left: 6px solid var(--oro);
			padding-left: 14px;
		}

		.title_block h1 {
		margin: 0;
		color: var(--primary);
		}

		.slider_block {
		margin: 0;
		display: grid;
		gap: 16px;
		height: calc(100vh - 120px);
		}

		.slider_block .single_slide {
		min-height: 220px;
		padding: 24px;
		background-size: cover;
		background-position: center;
		color: var(--bianco);
		position: relative;
		overflow: hidden;
		}

		.single_slide h1 {
		font-size: clamp(46px, 8vw, 128px);
		line-height: 0.95;
		text-shadow: 0 20px 38px rgba(0, 0, 0, 0.45);
		max-width: min(14ch, 100%);
		margin: 0;
		font-weight: 500;
		letter-spacing: -0.015em;
		}

		.single_slide h2 {
		font-size: clamp(17px, 2.2vw, 30px);
		line-height: 1.35;
		max-width: min(46ch, 100%);
		font-weight: 300;
		color: #e8e8e8;
		margin: 16px 0 0;
		}

		.slider_block .single_slide > .swiper-slide-container {
			position: relative;
			z-index: 1;
		}

		.slider_block .single_slide > .single_slide_bg {
			position: absolute;
			inset: 0;
			width: 100%;
			height: 100%;
			object-fit: cover;
			z-index: 0;
		}

		.slider_block .single_slide > .single_slide_video {
			position: absolute;
			inset: 0;
			width: 100%;
			height: 100%;
			object-fit: cover;
			z-index: 0;
		}

		.swiper-slide-container {
			margin: 0 auto;
			width: min(var(--SiteWidth), 100%);
			padding: 0 24px 60px;
			display: flex;
			flex-direction: column;
			justify-content: flex-end;
			height: 100%;
		}

	.single_slide {
		padding: 0;
		text-align: left;
		background-size: cover;
		background-position: center;
		min-height: 340px;
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 8px;
	}

	.slider_block .single_slide::before {
		content: "";
		position: absolute;
		inset: 0;
		background: linear-gradient(180deg, rgba(0, 0, 0, 0.2) 0%, rgba(0, 0, 0, 0.65) 100%);
		z-index: 0;
	}
	.slide_image_sr {
		display: none;
	}
	:global(.swiper-button-prev),
	:global(.swiper-button-next) {
		color: #fff;
		width: 42px;
		height: 42px;
		background: rgba(0, 0, 0, 0.34);
		border: 1px solid rgba(255, 255, 255, 0.4);
		border-radius: 999px;
	}

	:global(.swiper-button-prev)::after,
	:global(.swiper-button-next)::after {
		font-size: 14px;
		font-weight: 700;
	}

	:global(.swiper-pagination-bullet) {
		background: rgba(255, 255, 255, 0.45);
		opacity: 1;
	}

	:global(.swiper-pagination-bullet-active) {
		background: #fff;
	}

	@media (max-width: 640px) {
		.single_slide h1 {
			font-size: 48px;
			line-height: 0.95;
		}

		.swiper-slide-container {
			padding: 0 18px 44px;
		}
	}
</style>
