---
import { directusAssetUrl } from '../lib/directus';

interface SlideItem {
	titolo?: string;
	sottotitolo?: string;
	label?: string;
	href?: string;
	immagine?: string;
}

interface Props {
	slides?: SlideItem[];
	titolo?: string;
	sottotitolo?: string;
	label?: string;
	href?: string;
	autoplay?: boolean;
	autoplayDelay?: number;
}

const {
	slides = [],
	titolo = '',
	sottotitolo = '',
	label = '',
	href = '',
	autoplay = false,
	autoplayDelay = 3000,
} = Astro.props;

const resolvedSlides =
	slides.length > 0
		? slides
		: [
				{
					titolo,
					sottotitolo,
					label,
					href,
				},
		  ];

const hasMultipleSlides = resolvedSlides.length > 1;

const sliderId = `slider-${Math.random().toString(36).slice(2)}`;

function resolveImageSrc(value: string | undefined) {
	return directusAssetUrl(value, {
		width: 1920,
		height: 1080,
		quality: 72,
		format: 'webp',
	});
}

function getSlideImageMeta(slide: SlideItem) {
  const topic = slide.titolo?.trim() || 'Servizi CNC di precisione';
  return {
    alt: `${topic} - riaffilatura, rigenerazione e produzione utensili CNC`,
    title: `${topic} | affilatrici CNC a 5 assi e controllo qualita`
  };
}
---

<div
	class="slider_block swiper"
	id={sliderId}
	data-swiper-autoplay={autoplay && hasMultipleSlides ? 'true' : undefined}
	data-swiper-autoplay-delay={autoplay && hasMultipleSlides ? String(autoplayDelay) : undefined}
>
	<div class="swiper-wrapper">
		{resolvedSlides.map((slide, index) => (
			<div class="swiper-slide single_slide">
			{slide.immagine && (
				<img
					class="single_slide_bg"
					src={resolveImageSrc(slide.immagine)}
					alt={getSlideImageMeta(slide).alt}
					title={getSlideImageMeta(slide).title}
					loading={index === 0 ? 'eager' : 'lazy'}
					fetchpriority={index === 0 ? 'high' : 'auto'}
					decoding="async"
				/>
			)}
			<div class="swiper-slide-container">
				{slide.titolo && <h1 data-aos="fade-up" data-aos-duration="1500">{slide.titolo}</h1>}
				{slide.sottotitolo && <h2 data-aos="fade-up" data-aos-duration="1800">{slide.sottotitolo}</h2>}
				{slide.label && slide.href && (
					<button data-aos="fade-up" data-aos-duration="2000" class="slider_button MainButton" type="button" data-href={slide.href}>
						{slide.label}
					</button>
				)}
				{slide.immagine && (
					<span class="slide_image_sr" aria-hidden="true"></span>
				)}
			</div>
			</div>
		))}
	</div>
	{hasMultipleSlides && <div class="swiper-pagination"></div>}
	{hasMultipleSlides && <div class="swiper-button-prev"></div>}
	{hasMultipleSlides && <div class="swiper-button-next"></div>}
</div>


<style>
		.title_block {
			margin: 32px 0 16px;
			border-left: 6px solid var(--oro);
			padding-left: 14px;
		}

		.title_block h1 {
		margin: 0;
		color: var(--blu);
		}

		.slider_block {
		margin:0;
		display: grid;
		gap: 16px;
		height:calc(80vh - 120px);
		}

		.slider_block .single_slide {
		min-height: 220px;
		padding: 24px;
		background-size: cover;
		background-position: center;
		color: var(--bianco);
		position: relative;
		overflow: hidden;
		}

		.single_slide h1 {
		font-size:80px;
		line-height: 80px;
		text-shadow: 12px 6px 15px #000;
		max-width: calc(var(--max-width)/1.4);
		margin:0;
		}

		.single_slide h2 {
		font-size:25px;
		line-height: 30px;
		max-width: calc(var(--max-width)/2);
		}

		.slider_block .single_slide > .swiper-slide-container {
			position: relative;
			z-index: 1;
		}

		.slider_block .single_slide > .single_slide_bg {
			position: absolute;
			inset: 0;
			width: 100%;
			height: 100%;
			object-fit: cover;
			z-index: 0;
		}

		.swiper-slide-container {
			margin: auto;
			width: min(var(--SiteWidth), 100%);
			max-width: 100%;
		}

	.single_slide {
		text-align: center;
		padding: 20px;
		text-align: left;
		background-size: cover;
		background-position: center;
		min-height: 240px;
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 8px;
	}
	.slide_image_sr {
		display: none;
	}
	:global(.swiper-button-prev),
	:global(.swiper-button-next) {
		color: #111;
	}

	@media (max-width: 640px) {
		.slider_block {
			height: 85vh;
		}

		:global(.slider_block .swiper-button-prev),
		:global(.slider_block .swiper-button-next) {
			display: none;
		}

		.single_slide {
			padding: 16px;
		}

		.swiper-slide-container {
			width: 100%;
		}

		.single_slide h1 {
			font-size: clamp(30px, 10vw, 45px);
			line-height: 1.08;
			max-width: 100%;
			overflow-wrap: anywhere;
			hyphens: none;
		}

		.single_slide h2 {
			max-width: 100%;
			overflow-wrap: anywhere;
			hyphens: none;
		}
	}
</style>
