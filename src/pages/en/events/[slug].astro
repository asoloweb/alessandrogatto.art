---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { directusFetch, directusItemsUrl } from '../../../lib/directus';
import { eventoCoverUrl, formatEventoDateRange } from '../../../lib/eventi';
import { slugifyNewsTitle } from '../../../lib/news-slug';

type Evento = {
	id: number;
	status: string;
	titolo_evento: string;
	titolo_evento_en?: string;
	descrizione?: string;
	descrizione_en?: string;
	data_inizio?: string | null;
	data_fine?: string | null;
	foto_copertina?: string | null;
	location?: string | null;
	link_esterno?: string | null;
};

export async function getStaticPaths() {
	const url = directusItemsUrl('eventi');
	url.searchParams.set('fields', 'id,status,titolo_evento,titolo_evento_en,descrizione,descrizione_en,data_inizio,data_fine,foto_copertina,location,link_esterno');
	url.searchParams.set('filter[status][_eq]', 'published');
	url.searchParams.set('sort', '-data_inizio');
	const response = await directusFetch(url);
	const payload = await response.json();
	const items = Array.isArray(payload?.data) ? (payload.data as Evento[]) : [];
	const used = new Set<string>();

	return items.map((event) => {
		const title = event.titolo_evento_en || event.titolo_evento;
		const base = slugifyNewsTitle(title || '') || String(event.id);
		let slug = base;
		if (used.has(slug)) slug = `${base}-${event.id}`;
		used.add(slug);
		return { params: { slug }, props: { event } };
	});
}

const { event } = Astro.props as { event: Evento };
const title = event.titolo_evento_en || event.titolo_evento;
const description = event.descrizione_en || event.descrizione;
const imageSrc = eventoCoverUrl(event.foto_copertina || null);
const dateLabel = formatEventoDateRange(event.data_inizio || null, event.data_fine || null, 'en');
---

<BaseLayout title={title || 'Event'}>
	<article class="event_single">
		<div class="event_single_inner">
			{dateLabel && <p class="event_single_date">{dateLabel}</p>}
			<h1 class="event_single_title">{title}</h1>
			{event.location && <p class="event_single_location">{event.location}</p>}
			{imageSrc && (
				<div class="event_single_media">
					<img src={imageSrc} alt={title || ''} loading="eager" />
				</div>
			)}
			{description && <div class="event_single_editor" set:html={description} />}
			{event.link_esterno && (
				<a class="MainButton event_single_link" href={event.link_esterno} target="_blank" rel="noopener noreferrer">
					View more
				</a>
			)}
		</div>
	</article>
</BaseLayout>

<style>
	.event_single { padding: 165px 20px 60px; }
	.event_single_inner { max-width: var(--max-width); margin: 0 auto; }
	.event_single_date { margin: 0 0 10px; font-size: 14px; font-weight: 600; opacity: 0.8; }
	.event_single_title { margin: 0; font-size: clamp(34px, 5vw, 54px); line-height: 1.05; }
	.event_single_location { margin: 14px 0 24px; font-size: 16px; color: var(--text-muted); }
	.event_single_media { margin: 0 0 30px; overflow: hidden; border: 1px solid var(--border); }
	.event_single_media img { width: 100%; height: auto; display: block; }
	.event_single_editor { font-size: 18px; line-height: 1.65; }
	.event_single_link { margin-top: 30px; display: inline-flex; }
</style>
