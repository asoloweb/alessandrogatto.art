---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageContent from '../components/PageContent.astro';
import { fetchPublishedPageBySlug } from '../lib/pages';

const page = await fetchPublishedPageBySlug('chi-sono-filosofia');
---

<BaseLayout title={page?.title || 'Chi sono / Filosofia'} seoTitle={page?.seo_title} seoDescription={page?.seo_desc}>
	<PageContent page={page as any} notFoundTitle="Pagina non trovata" notFoundMessage="Contenuto non disponibile." />
</BaseLayout>
