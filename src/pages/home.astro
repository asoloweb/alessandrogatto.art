---
const target = '/';
---

<!doctype html>
<html lang="it">
	<head>
		<meta charset="utf-8" />
		<script>
			if (window.location.hostname === 'www.stevanin.it') {
				window.location.replace(`https://stevanin.it${window.location.pathname}${window.location.search}${window.location.hash}`);
			}
		</script>
		<meta http-equiv="refresh" content={`0; url=${target}`} />
		<link rel="canonical" href={target} />
		<title>Redirect</title>
	</head>
	<body>
		<p>Redirecting…</p>
	</body>
</html>
